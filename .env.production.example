# SkillStorm production environment example.
# Copy to .env.production or your secret manager. Do not commit real values.
# Generate all secret values with a cryptographically secure generator.
#
# Recommended compose command:
# docker compose --env-file .env.production -f docker-compose.prod.yml config

PROD_POSTGRES_USER=skillstorm
PROD_POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_POSTGRES_PASSWORD
PROD_POSTGRES_DB=skillstorm

# Must point at the internal Docker hostname used by docker-compose.prod.yml.
PROD_DATABASE_URL=CHANGE_ME_DATABASE_URL

# Required: unique strong random values, at least 32 characters.
PROD_JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_ACCESS_SECRET
PROD_JWT_REFRESH_SECRET=CHANGE_ME_STRONG_RANDOM_REFRESH_SECRET
PROD_COOKIE_SECRET=CHANGE_ME_STRONG_RANDOM_COOKIE_SECRET
PROD_METRICS_INGEST_KEY=CHANGE_ME_STRONG_RANDOM_METRICS_INGEST_KEY

# Production security controls.
# DISABLE_CSRF is hard-coded to 0 in docker-compose.prod.yml.
# ENABLE_SWAGGER is hard-coded to 0 in docker-compose.prod.yml.
PROD_ALLOW_CROSS_SITE_COOKIES=0
PROD_ALLOW_PUBLIC_ORG_CREATION=false
PROD_RUN_MIGRATIONS=1
PROD_RUN_SEED=0

PROD_CORS_ORIGINS=https://app.example.com
PROD_PUBLIC_APP_URL=https://app.example.com
PROD_API_URL=https://app.example.com
PROD_API_PROXY_TARGET=http://backend:4200

# External frontend port published by the production compose file.
PROD_FRONTEND_PORT=3000
PROD_ENABLE_RBAC_TELEMETRY_CLIENT=0
PROD_BETA_MODE=

# Optional one-time bootstrap only when no SUPERADMIN exists.
# Leave empty for normal deploys after bootstrap is complete.
PROD_SUPERADMIN_EMAIL=
PROD_SUPERADMIN_PASSWORD=

# Behind a reverse proxy (Render, nginx): trust 1 hop so req.ip is the real
# client IP — per-IP rate limiting breaks without it. Leave unset for direct.
TRUST_PROXY=1

# Error tracking (optional)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# SkillStorm — test environment example
#
# Copy to `.env.test` for local test runs:
#   cp server/.env.test.example server/.env.test
#
# `test/jest-env.js` loads `.env.test` if present, otherwise falls back to
# THIS file, so a fresh clone can run the pure-unit suites (mocked Prisma)
# without any manual setup. DB-backed integration/e2e suites additionally
# require a reachable Postgres at DATABASE_URL_TEST with the schema migrated
# (see docs/testing.md).

# The test database is configured EXCLUSIVELY via DATABASE_URL_TEST.
# Any DATABASE_URL inherited from the shell or another .env is DISCARDED by
# the test setup, and a safety guard (server/scripts/db-safety.js) refuses to
# run destructive test tooling (migrate reset, DROP SCHEMA, e2e seed) unless
# the database NAME ends with "_test". The guard has no bypass.
#
# Keep `schema=public` pinned so `prisma migrate reset` and the test runtime
# use the same schema. Point ONLY at a dedicated, disposable test database.
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/skillstorm_test?schema=public

# Test-only JWT secrets — NEVER reuse in any real environment.
JWT_ACCESS_SECRET=test-only-access-secret-not-for-production
JWT_REFRESH_SECRET=test-only-refresh-secret-not-for-production

# Test toggles (jest-env sets sane defaults too).
DISABLE_CSRF=1
DISABLE_THROTTLE=1
DISABLE_STATS_CACHE=1
CACHE_TTL_SECONDS=0

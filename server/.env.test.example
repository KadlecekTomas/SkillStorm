# SkillStorm — test environment example
#
# Copy to `.env.test` for local test runs:
#   cp server/.env.test.example server/.env.test
#
# `test/jest-env.js` loads `.env.test` if present, otherwise falls back to
# THIS file, so a fresh clone can run the pure-unit suites (mocked Prisma)
# without any manual setup. DB-backed integration/e2e suites additionally
# require a reachable Postgres at DATABASE_URL with the schema migrated
# (see docs/testing.md).

# Local Postgres used by DB-backed suites. jest-env appends an isolated
# `schema=e2e_<ts>_<rand>` per run when no schema= is present.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillstorm_test

# Test-only JWT secrets — NEVER reuse in any real environment.
JWT_ACCESS_SECRET=test-only-access-secret-not-for-production
JWT_REFRESH_SECRET=test-only-refresh-secret-not-for-production

# Test toggles (jest-env sets sane defaults too).
DISABLE_CSRF=1
DISABLE_THROTTLE=1
DISABLE_STATS_CACHE=1
CACHE_TTL_SECONDS=0

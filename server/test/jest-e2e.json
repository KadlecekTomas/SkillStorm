{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": "../",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "preset": "ts-jest",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "^shared/(.*)$": "<rootDir>/shared/$1"
  },
  "modulePaths": ["<rootDir>"]
}

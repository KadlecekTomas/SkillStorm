# Backend local development environment example.
# Copy to server/.env for local development only. Never commit real env files.

NODE_ENV=development
PORT=4200
DATABASE_URL=CHANGE_ME_DATABASE_URL

# Use strong random values even in shared dev environments.
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_RANDOM_REFRESH_SECRET
COOKIE_SECRET=CHANGE_ME_STRONG_RANDOM_COOKIE_SECRET
METRICS_INGEST_KEY=CHANGE_ME_LOCAL_METRICS_INGEST_KEY

PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:3000
ALLOW_CROSS_SITE_COOKIES=0

# Local-only toggles. DISABLE_CSRF=1 is forbidden in production.
DISABLE_CSRF=0
ALLOW_PUBLIC_ORG_CREATION=true
RUN_MIGRATIONS=1
RUN_SEED=0
DEMO_SEED=0
DEMO_MODE=0
CACHE_TTL_SECONDS=60

# One-time bootstrap only when no SUPERADMIN exists.
SUPERADMIN_EMAIL=admin@skillstorm.local
SUPERADMIN_PASSWORD=CHANGE_ME_STRONG_RANDOM_BOOTSTRAP_PASSWORD

NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/skillstorm
JWT_SECRET=dev
PORT=4200
ALLOW_PUBLIC_ORG_CREATION=true

# =====================================================
# SUPERADMIN BOOTSTRAP (ONE-TIME ONLY)
# These variables are used ONLY if no SUPERADMIN exists.
# In production, REQUIRED when no SUPERADMIN (startup check).
# =====================================================

SUPERADMIN_EMAIL=admin@skillstorm.local
SUPERADMIN_PASSWORD=ChangeMeImmediately!

# -----------------------------------------------------
# PRODUCTION (closed beta): required at startup
# -----------------------------------------------------
# DATABASE_URL=   (required)
# JWT_SECRET=     (required; no default)
# CORS_ORIGINS=   (required, e.g. https://beta.example.com)
# BETA_ALLOWLIST_EMAILS=  (comma-separated; empty = invite-only)
# SENTRY_DSN=     (optional)

# -----------------------------------------------------
# WARNING:
# Environment variables are used ONLY for initial bootstrap.
# Authorization is ALWAYS driven by database state.
# -----------------------------------------------------

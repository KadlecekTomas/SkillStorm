{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:e2e": "node scripts/assert-test-db.js && nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "test": "jest",
    "test:unit:light": "jest --config ./jest.unit.config.js --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:gamification": "jest gamification",
    "test:policy": "vitest run tests/policy/policy.summary.test.ts --reporter=dot",
    "prisma:seed": "ts-node -r tsconfig-paths/register prisma/seed/e2e-seed.ts",
    "seed:validate": "ts-node -r tsconfig-paths/register prisma/seed/validate-seed.ts",
    "seed:demo": "ts-node prisma/seed/demo-flow-seed.ts",
    "seed:demo:profile": "node prisma/demo-seed.js",
    "seed:full": "ts-node prisma/seed/full-walkthrough-seed.ts",
    "seed:defense-screenshots": "ts-node prisma/seed/defense-screenshot-seed.ts",
    "seed:production": "ts-node prisma/seed/full-production-seed.ts",
    "seed:prod:a": "ts-node prisma/seed/full-production-seed.ts --variant=A",
    "seed:prod:b": "ts-node prisma/seed/full-production-seed.ts --variant=B",
    "seed:verify": "ts-node prisma/seed/seed-verify.ts",
    "test:e2e": "cross-env NODE_ENV=test jest --config ./test/jest-e2e.config.js --maxWorkers=1",
    "verify:enrollments": "ts-node scripts/verify-enrollments.ts",
    "verify:submissions": "ts-node scripts/verify-submissions.ts",
    "bootstrap:search": "ts-node scripts/bootstrap-search-all.ts",
    "prebuild": "npm run prisma:generate && npm run typecheck",
    "db:seed": "npx prisma db seed"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/typeorm": "^10.0.0",
    "@prisma/client": "^6.13.0",
    "@sentry/node": "^10.65.0",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.1.1",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.1",
    "typeorm": "^0.3.16",
    "xlsx": "^0.18.5",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cache-manager": "^4.0.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/date-fns": "^2.5.3",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.25",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "prisma": "^6.6.0",
    "prisma-erd-generator": "^2.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.1",
    "ts-loader": "^9.4.3",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "vitest": "^4.0.8"
  }
}

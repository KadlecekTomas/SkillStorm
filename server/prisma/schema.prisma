generator client {
  provider      = "prisma-client-js"
  output        = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//
enum Role {
  STUDENT
  TEACHER
  DIRECTOR
  SUPERADMIN
}

enum QuestionType {
  FILL_IN_THE_BLANK
  MULTIPLE_CHOICE
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

//
// USER MANAGEMENT
//
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String
  role          Role
  passwordHash  String
  tests         Test[]         @relation("TeacherTests")
  submissions   Submission[]
  refreshTokens RefreshToken[]
  gamification  Gamification?
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())

  directorSchool School?  @relation("DirectorSchool")
  teacherProfile Teacher?
  studentProfile Student?

  @@index([role]) // Často budeme filtrovat uživatele podle role
}

//
// AUTH
//
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

//
// GAMIFICATION
//
model Gamification {
  id     String  @id @default(uuid())
  user   User    @relation(fields: [userId], references: [id])
  userId String  @unique
  xp     Int     @default(0)
  level  Int     @default(1)
  avatar String?
}

//
// TESTS & QUESTIONS
//
model Test {
  id          String       @id @default(uuid())
  title       String
  description String?
  creator     User         @relation("TeacherTests", fields: [creatorId], references: [id])
  creatorId   String
  questions   Question[]
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Question {
  id        String       @id @default(uuid())
  text      String
  type      QuestionType
  test      Test         @relation(fields: [testId], references: [id])
  testId    String
  options   Option[]
  answers   Answer[]
  responses Response[]
}

model Option {
  id         String   @id @default(uuid())
  text       String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
}

model Answer {
  id         String   @id @default(uuid())
  text       String
  question   Question @relation(fields: [questionId], references: [id])
  questionId String
}

//
// SUBMISSIONS & RESPONSES
//
model Submission {
  id          String           @id @default(uuid())
  student     User             @relation(fields: [studentId], references: [id])
  studentId   String
  test        Test             @relation(fields: [testId], references: [id])
  testId      String
  responses   Response[]
  score       Float?
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime         @default(now())

  @@index([studentId]) // Pro rychlé vyhledávání pokusů studenta
  @@index([testId]) // Pro rychlé vyhledávání odevzdání podle testu
}

model Response {
  id           String     @id @default(uuid())
  submission   Submission @relation(fields: [submissionId], references: [id])
  submissionId String
  question     Question   @relation(fields: [questionId], references: [id])
  questionId   String
  givenText    String
  isCorrect    Boolean?
  feedback     String?
}

//
// AUDIT LOGS
//
model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())
}

//
// STATS VIEW (PostgreSQL VIEW – jen pro čtení)
//
model TaskCompletionStats {
  test_id           String
  title             String
  total_submissions Int
  passed_count      Int
  pass_rate         Float

  @@ignore // View – nelze zapisovat
}

model School {
  id         String      @id @default(uuid())
  name       String
  address    String?
  city       String?
  country    String?
  director   User        @relation("DirectorSchool", fields: [directorId], references: [id])
  directorId String      @unique
  teachers   Teacher[]
  classrooms Classroom[]
  subjects   Subject[]
  createdAt  DateTime    @default(now())
}

model Teacher {
  id       String           @id @default(uuid())
  user     User             @relation(fields: [userId], references: [id])
  userId   String           @unique
  school   School           @relation(fields: [schoolId], references: [id])
  schoolId String
  subjects TeacherSubject[]
  classes  Classroom[]      @relation("ClassroomTeacher")

  @@index([schoolId]) // Vyhledávání učitelů podle školy
}

model Student {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String    @unique
  classroom   Classroom @relation(fields: [classroomId], references: [id])
  classroomId String

  @@index([classroomId]) // Vyhledávání studentů podle třídy
}

model Classroom {
  id        String    @id @default(uuid())
  name      String
  school    School    @relation(fields: [schoolId], references: [id])
  schoolId  String
  teacher   Teacher?  @relation("ClassroomTeacher", fields: [teacherId], references: [id])
  teacherId String?
  students  Student[]
  subjects  Subject[]

  @@index([schoolId]) // Vyhledávání tříd podle školy
}

model Subject {
  id         String           @id @default(uuid())
  name       String
  school     School           @relation(fields: [schoolId], references: [id])
  schoolId   String
  teachers   TeacherSubject[]
  classrooms Classroom[]

  @@index([schoolId]) // Vyhledávání předmětů podle školy
}

model TeacherSubject {
  id        String  @id @default(uuid())
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  teacherId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String
}

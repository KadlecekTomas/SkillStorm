  MIDDLE // 4.–9. ZŠ (default při neznámém ročníku)
  SENIOR // SŠ
}

/// Výsledek kola v režimu B — zadává učitel, žádné počítání jednotlivých dětí.
enum LiveRoundOutcome {
  MOSTLY_CORRECT
  SPLIT
  MOSTLY_WRONG
}

/// Jediné povolené zdroje XP třídního parťáka. Správnost odpovědí

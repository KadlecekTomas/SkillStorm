enum AnalyticsSnapshotSource {
  LIVE_SUBMIT
  BACKFILL
}

/// Typ interakce kola bleskovky. QUIZ = A/B/C/D + pravda/nepravda (vč.
/// hlasování); ostatní se řeší drag & dropem přímo na tabuli. Jak přidat
/// další typ viz docs/live-sessions-interactions.md.
enum RoundInteractionType {
  QUIZ
  MATCH_PAIRS
  ORDER
  SORT_BINS
}

enum LiveSessionMode {
  BOARD_ONLY // režim B — MVP: vše na učitelově obrazovce
  DEVICES // režim A — žáci na vlastních zařízeních (zatím neimplementováno)
}


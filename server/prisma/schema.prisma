generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String               @id @default(uuid()) @map("user_id")
  email                  String?              @unique @db.VarChar(320)
  username               String?              @unique @db.VarChar(64)
  passwordHash           String               @map("password_hash") @db.VarChar(255)
  name                   String               @db.VarChar(150)
  preferredLang          String?              @map("preferred_lang") @db.VarChar(10)
  systemRole             SystemRole?          @map("system_role")
  status                 UserStatus           @default(ACTIVE)
  lastLoginAt            DateTime?            @map("last_login_at")
  passwordChangedAt      DateTime?            @map("password_changed_at")
  tokenVersion           Int                  @default(0) @map("token_version")
  // Prezentační preference basic/detail (guardian spec bod 4) — nikdy
  // nemění oprávnění, jen zobrazení už povolených dat.
  interfaceDetailLevel   InterfaceDetailLevel @default(BASIC) @map("interface_detail_level")
  lastActiveMembershipId String?              @unique @map("last_active_membership_id")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  deletedAt              DateTime?            @map("deleted_at")
  anonymized             Boolean              @default(false)
  anonymizedAt           DateTime?            @map("anonymized_at")
  isPlatformAdmin        Boolean              @default(false) @map("is_platform_admin")
  analyticsEvents        AnalyticsEvent[]
  auditLogs              AuditLog[]
  supportTickets         SupportTicket[]
  assignedSupportTickets SupportTicket[]      @relation("SupportAssignedTo")
  resolvedSupportTickets SupportTicket[]      @relation("SupportResolvedBy")
  materialPurchases      MaterialPurchase[]
  memberships            Membership[]
  idempotencyKeys        IdempotencyKey[]
  refreshTokens          RefreshToken[]
  revokedTokens          RevokedToken[]
  passwordResetTokens    PasswordResetToken[]
  userPermissions        UserPermission[]
  identities             UserIdentity[]
  lastActiveMembership   Membership?          @relation("LastActiveMembership", fields: [lastActiveMembershipId], references: [id], onDelete: SetNull)
  ownedOrganizations     Organization[]       @relation("OrganizationOwner")

  @@index([username])
  @@map("users")
}

model Organization {
  id                 String                @id @default(uuid()) @map("organization_id")
  name               String                @db.VarChar(255)
  address            String?               @db.VarChar(255)
  city               String?               @db.VarChar(100)
  country            String?               @db.VarChar(100)
  type               OrganizationType      @default(SCHOOL)
  status             OrganizationStatus    @default(PENDING)
  ownerUserId        String?               @unique @map("owner_user_id")
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  deletedAt          DateTime?             @map("deleted_at")
  owner              User?                 @relation("OrganizationOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  academicYears      AcademicYear[]
  analyticsEvents    AnalyticsEvent[]
  assignments        Assignment[]
  enrollments        Enrollment[]
  auditLogs          AuditLog[]
  classSections      ClassSection[]
  exportLogs         ExportLog[]
  importBatches      ImportBatch[]
  learningMaterials  LearningMaterial[]
  materialPurchases  MaterialPurchase[]
  memberships        Membership[]
  settings           OrganizationSettings?
  rolePermissions    RolePermission[]
  students           Student[]
  orgSubjects        OrgSubject[]
  subscriptions      Subscription[]
  teachers           Teacher[]
  tests              Test[]
  userPermissions    UserPermission[]
  invitations        Invitation[]
  invites            Invite[]
  promotionLogs      PromotionLog[]
  submissions        Submission[]
  supportTickets     SupportTicket[]
  userIdentities     UserIdentity[]
  liveSessions       LiveSession[]
  classPartaks       ClassPartak[]
  campaignProgresses CampaignProgress[]
  guardianRelations  GuardianStudentRelation[]

  @@index([name])
  @@index([city])
  @@index([status])
  @@map("organizations")
}

enum OrganizationStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model OrganizationSettings {
  id                     String       @id @default(uuid()) @map("organization_settings_id")
  orgId                  String       @unique @map("organization_id")
  usernamePattern        String       @default("{surname}{fi}{yy}")
  domainAlias            String?
  initialPassword        String       @default("ChangeMe!{yy}")
  forceResetOnFirstLogin Boolean      @default(true)
  ssoProvider            String?
  ssoAllowedDomains      String[]     @default([]) @map("sso_allowed_domains")
  ssoAutoProvision       Boolean      @default(false) @map("sso_auto_provision")
  organization           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

/// External identity (SSO) linked to a local user account.
///
/// IDENTITY IS GLOBAL, ACCESS IS MEMBERSHIP: one user has at most one
/// identity per provider ((userId, provider) unique) and that identity
/// authenticates the user into ANY organization where they hold a live
/// Membership. `organizationId` here is PROVENANCE ONLY — it records which
/// organization's SSO policy admitted/provisioned the identity (for audit
/// and GDPR scoping). It never restricts which organizations the user can
/// log into. The (provider, providerSubject) pair is globally unique
/// because provider subjects (e.g. Google `sub`) are global.
model UserIdentity {
  id              String           @id @default(uuid()) @map("user_identity_id")
  userId          String           @map("user_id")
  organizationId  String?          @map("organization_id")
  provider        IdentityProvider
  providerSubject String           @map("provider_subject") @db.VarChar(255)
  email           String?          @db.VarChar(320)
  emailVerified   Boolean          @default(false) @map("email_verified")
  displayName     String?          @map("display_name") @db.VarChar(150)
  lastUsedAt      DateTime?        @map("last_used_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([organizationId, provider])
  @@index([email])
  @@map("user_identities")
}

enum IdentityProvider {
  GOOGLE
}

model IdempotencyKey {
  id          String   @id @default(uuid()) @map("idempotency_key_id")
  userId      String   @map("user_id")
  key         String   @map("key") @db.VarChar(255)
  operation   String   @db.VarChar(100)
  requestHash String   @map("request_hash") @db.VarChar(64)
  result      Json?    @map("result")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, operation, key])
  @@index([userId, operation, createdAt])
  @@map("idempotency_keys")
}

model Membership {
  id                 String                   @id @default(uuid()) @map("membership_id")
  userId             String                   @map("user_id")
  organizationId     String                   @map("organization_id")
  role               OrganizationRole
  lastActiveRole     OrganizationRole?        @map("last_active_role")
  xp                 Int                      @default(0)
  level              Int                      @default(1)
  avatarType         String?                  @map("avatar_type") @db.VarChar(50)
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  deletedAt          DateTime?                @map("deleted_at")
  assignmentStudents AssignmentStudent[]
  createdAssignments Assignment[]             @relation("AssignmentCreatedBy")
  exportedLogs       ExportLog[]
  importedBatches    ImportBatch[]
  createdMaterials   LearningMaterial[]
  achievements       MembershipAchievement[]
  badges             MembershipBadge[]
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastActiveFor      User?                    @relation("LastActiveMembership")
  student            Student?
  submissions        Submission[]
  teacher            Teacher?
  createdTests       Test[]
  xpEvents           XpEvent[]
  hostedLiveSessions LiveSession[]            @relation("HostedLiveSessions")
  liveParticipations LiveSessionParticipant[]
  roleAssignments    MembershipRoleAssignment[]
  guardianRelations  GuardianStudentRelation[] @relation("GuardianRelations")
  verifiedGuardianRelations GuardianStudentRelation[] @relation("VerifiedGuardianRelations")
  revokedGuardianRelations  GuardianStudentRelation[] @relation("RevokedGuardianRelations")
  createdInvites     Invite[]                  @relation("CreatedInvites")

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@index([userId])
  @@map("memberships")
}

/// Přiřazené role membershipu (multi-role, guardian Etapa A).
/// Membership.role zůstává primární rolí; invariant „primární role má aktivní
/// assignment" vynucuje deferred constraint trigger membership_primary_role_guard
/// + jediná servisní cesta zápisu (MembershipRolesService).
model MembershipRoleAssignment {
  id           String           @id @default(uuid()) @map("membership_role_assignment_id")
  membershipId String           @map("membership_id")
  role         OrganizationRole
  createdAt    DateTime         @default(now()) @map("created_at")
  createdById  String?          @map("created_by_membership_id")
  deletedAt    DateTime?        @map("deleted_at")
  membership   Membership       @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, role])
  @@index([role])
  @@map("membership_role_assignments")
}

model Level {
  id        String   @id @default(uuid()) @map("level_id")
  levelNo   Int      @unique @map("level_no")
  minXp     Int      @map("min_xp")
  badgeUrl  String?  @map("badge_url")
  rewards   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("levels")
}

model XpEvent {
  id           String      @id @default(uuid()) @map("xp_event_id")
  membershipId String      @map("membership_id")
  type         XpEventType @map("event_type")
  value        Int
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at")
  metadata     Json?
  membership   Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([membershipId, type])
  @@map("xp_events")
}

model Achievement {
  id          String                  @id @default(uuid()) @map("achievement_id")
  title       String
  description String?
  iconUrl     String?                 @map("icon_url")
  condition   Json?
  createdAt   DateTime                @default(now()) @map("created_at")
  memberships MembershipAchievement[]

  @@map("achievements")
}

model MembershipAchievement {
  id            String      @id @default(uuid()) @map("membership_achievement_id")
  membershipId  String      @map("membership_id")
  achievementId String      @map("achievement_id")
  achievedAt    DateTime    @default(now()) @map("achieved_at")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  membership    Membership  @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, achievementId])
  @@map("membership_achievements")
}

model BadgeDefinition {
  id          String            @id @default(uuid()) @map("badge_definition_id")
  code        String            @unique @db.VarChar(100)
  name        String            @db.VarChar(150)
  description String?           @db.VarChar(255)
  iconKey     String?           @map("icon_key") @db.VarChar(100)
  xpReward    Int?              @map("xp_reward")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  awards      MembershipBadge[]

  @@index([code])
  @@map("badge_definitions")
}

model MembershipBadge {
  id                String          @id @default(uuid()) @map("membership_badge_id")
  membershipId      String          @map("membership_id")
  badgeDefinitionId String          @map("badge_definition_id")
  awardedAt         DateTime        @default(now()) @map("awarded_at")
  metadata          Json?
  badgeDefinition   BadgeDefinition @relation(fields: [badgeDefinitionId], references: [id], onDelete: Cascade)
  membership        Membership      @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, badgeDefinitionId])
  @@index([membershipId, awardedAt])
  @@index([badgeDefinitionId])
  @@map("membership_badges")
}

model Permission {
  id              String             @id @default(uuid()) @map("permission_id")
  key             PermissionKey      @unique
  description     String?
  allowedTypes    OrganizationType[]
  category        String?            @db.VarChar(100)
  isDeprecated    Boolean            @default(false) @map("is_deprecated")
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@map("permissions")
}

model RolePermission {
  id             String           @id @default(uuid()) @map("role_permission_id")
  role           OrganizationRole
  permissionId   String           @map("permission_id")
  allowed        Boolean          @default(true)
  organizationId String?          @map("organization_id")
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permission     Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([organizationId, role, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id             String        @id @default(uuid()) @map("user_permission_id")
  userId         String        @map("user_id")
  permissionId   String        @map("permission_id")
  allowed        Boolean       @default(true)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  permission     Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, permissionId])
  @@map("user_permissions")
}

model Subscription {
  id             String             @id @default(uuid()) @map("subscription_id")
  organizationId String             @map("organization_id")
  planId         String             @map("plan_id")
  status         SubscriptionStatus
  startDate      DateTime           @map("start_date")
  endDate        DateTime           @map("end_date")
  createdAt      DateTime           @default(now()) @map("created_at")
  deletedAt      DateTime?          @map("deleted_at")
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([planId])
  @@map("subscriptions")
}

model SubscriptionPlan {
  id            String         @id @default(uuid()) @map("plan_id")
  name          String
  target        PlanTarget
  price         Decimal        @db.Decimal(10, 2)
  currency      String         @db.VarChar(3)
  billingCycle  String         @map("billing_cycle") @db.VarChar(50)
  maxUsers      Int?           @map("max_users")
  features      Json
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model RefreshToken {
  id        String    @id @default(uuid()) @map("refresh_token_id")
  token     String    @unique @db.Text
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model RevokedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("revoked_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @map("password_reset_token_id")
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model AuditLog {
  id             String          @id @default(uuid()) @map("audit_log_id")
  userId         String?         @map("user_id")
  organizationId String?         @map("organization_id")
  systemRole     String?         @map("system_role")
  entityType     AuditEntityType @map("entity_type")
  entityId       String?         @map("entity_id")
  action         String
  ipAddress      String?         @map("ip_address")
  userAgent      String?         @map("user_agent")
  metadata       Json?
  changedFields  Json?           @map("changed_fields")
  createdAt      DateTime        @default(now()) @map("created_at")
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

model SupportTicket {
  id             String                @id @default(uuid()) @map("support_ticket_id")
  organizationId String                @map("organization_id")
  userId         String                @map("user_id")
  category       String                @db.VarChar(100)
  message        String
  page           String?               @db.VarChar(255)
  metadata       Json?
  status         SupportTicketStatus   @default(OPEN)
  priority       SupportTicketPriority @default(MEDIUM)
  assignedToId   String?               @map("assigned_to_id")
  internalNote   String?               @map("internal_note")
  resolutionNote String?               @map("resolution_note")
  resolvedById   String?               @map("resolved_by_id")
  resolvedAt     DateTime?             @map("resolved_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedTo     User?                 @relation("SupportAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedBy     User?                 @relation("SupportResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([userId, createdAt])
  @@index([assignedToId, status])
  @@index([resolvedById])
  @@map("support_tickets")
}

model AnalyticsEvent {
  id             String        @id @default(uuid()) @map("analytics_event_id")
  userId         String?       @map("user_id")
  organizationId String?       @map("organization_id")
  category       String        @db.VarChar(100)
  action         String        @db.VarChar(100)
  metadata       Json?
  createdAt      DateTime      @default(now()) @map("created_at")
  label          String?       @db.VarChar(120)
  value          Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])

  @@index([organizationId, category])
  @@map("analytics_events")
}

/// @deprecated Legacy invite model. Use Invite instead.
model Invitation {
  id                    String            @id @default(uuid()) @map("invitation_id")
  organizationId        String            @map("organization_id")
  type                  InvitationType    @default(ORG_ONLY)
  role                  OrganizationRole?
  classSectionId        String?           @map("class_section_id")
  yearId                String?           @map("academic_year_id")
  code                  String            @unique @db.VarChar(64)
  expiresAt             DateTime          @map("expires_at")
  maxUses               Int               @default(1) @map("max_uses")
  usedCount             Int               @default(0) @map("used_count")
  revokedAt             DateTime?         @map("revoked_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  createdByMembershipId String?           @map("created_by_membership_id")
  organization          Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classSection          ClassSection?     @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  academicYear          AcademicYear?     @relation(fields: [yearId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([code])
  @@map("invitations")
}

model Invite {
  id             String           @id @default(uuid()) @map("invite_id")
  organizationId String           @map("organization_id")
  type           InvitationType   @default(ORG_ONLY)
  token          String           @unique @db.VarChar(64)
  code           String?          @unique @db.VarChar(64)
  role           OrganizationRole
  classSectionId String?          @map("class_section_id")
  yearId         String?          @map("academic_year_id")
  // GUARDIAN pozvánka: koho kód propojuje (aplikační vrstva vynucuje
  // non-null pro type=GUARDIAN) + kdo za školu kód vystavil (provenance
  // pro verified_by na vztahu).
  targetStudentId String?         @map("target_student_id")
  createdById     String?         @map("created_by_membership_id")
  expiresAt      DateTime         @map("expires_at")
  maxUses        Int              @default(1) @map("max_uses")
  usedCount      Int              @default(0) @map("used_count")
  revokedAt      DateTime?        @map("revoked_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classSection   ClassSection?    @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear?    @relation(fields: [yearId], references: [id], onDelete: Cascade)
  targetStudent  Student?         @relation("GuardianInvites", fields: [targetStudentId], references: [id], onDelete: Cascade)
  createdBy      Membership?      @relation("CreatedInvites", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@index([classSectionId])
  @@index([yearId])
  @@index([targetStudentId])
  @@map("invites")
}

enum InvitationType {
  ORG_ONLY
  STUDENT_CLASS
  GUARDIAN
}

enum GuardianRelationType {
  PARENT
  LEGAL_GUARDIAN
  OTHER
}

enum GuardianRelationStatus {
  PENDING
  VERIFIED
  DISPUTED
  REVOKED
}

enum GuardianPermissionKey {
  VIEW_RESULTS
  VIEW_ASSIGNMENTS
  START_PRACTICE
  START_HOMEWORK
  START_TEST
  RECEIVE_NOTIFICATIONS
  MANAGE_STUDENT_ACCESS
  RESET_STUDENT_PIN
}

enum InterfaceDetailLevel {
  BASIC
  DETAILED
}

// Vztah rodič/zákonný zástupce ↔ žák. Guardian strana je Membership (role
// PARENT z Etapy A), dětská strana org-scoped Student profil. Řádky se
// nikdy nemažou — REVOKED/DISPUTED je konečný doménový stav; nový přístup
// = nový řádek. Org konzistenci obou stran vynucují composite FK v SQL
// migraci (vzor enrollments_student_org_fk); „jeden živý vztah na pár"
// drží partial unique index guardian_relation_single_live_per_pair.
model GuardianStudentRelation {
  id                   String                  @id @default(uuid()) @map("guardian_student_relation_id")
  guardianMembershipId String                  @map("guardian_membership_id")
  studentId            String                  @map("student_id")
  organizationId       String                  @map("organization_id")
  type                 GuardianRelationType    @default(PARENT)
  status               GuardianRelationStatus  @default(PENDING)
  permissions          GuardianPermissionKey[] @default([])
  verifiedAt           DateTime?               @map("verified_at")
  verifiedById         String?                 @map("verified_by_membership_id")
  disputedAt           DateTime?               @map("disputed_at")
  revokedAt            DateTime?               @map("revoked_at")
  revokedById          String?                 @map("revoked_by_membership_id")
  validUntil           DateTime?               @map("valid_until")
  notificationPrefs    Json?                   @map("notification_prefs")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")
  guardianMembership   Membership              @relation("GuardianRelations", fields: [guardianMembershipId], references: [id], onDelete: Cascade)
  student              Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)
  organization         Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  verifiedBy           Membership?             @relation("VerifiedGuardianRelations", fields: [verifiedById], references: [id], onDelete: SetNull)
  revokedBy            Membership?             @relation("RevokedGuardianRelations", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([studentId])

model Response {
  id                    String     @id @default(uuid()) @map("response_id")
  submissionId          String     @map("submission_id")
  questionId            String     @map("question_id")
  givenText             String
  isCorrect             Boolean?
  awardedPoints         Int?       @map("awarded_points")
  maxPoints             Int?       @map("max_points")
  correctAnswerSnapshot String?    @map("correct_answer_snapshot")
  questionTextSnapshot  String?    @map("question_text_snapshot")
  feedback              String?
  explanation           String?
  attemptNumber         Int        @default(1) @map("attempt_number")
  corrected             Boolean?   @default(false)
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  question              Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  submission            Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([questionId])
  @@map("responses")
}

/// Bleskovka — živé cvičení pro celou třídu. MVP = BOARD_ONLY (režim B):
/// vše běží na učitelově obrazovce, žádná data o jednotlivých žácích.
/// Švy pro režim A (DEVICES) viz docs/live-sessions.md.
model LiveSession {
  id                 String                   @id @default(uuid()) @map("live_session_id")
  organizationId     String                   @map("organization_id")
  hostId             String                   @map("host_membership_id")
  classSectionId     String?                  @map("class_section_id")
  testId             String                   @map("test_id")
  mode               LiveSessionMode          @default(BOARD_ONLY)
  status             LiveSessionStatus        @default(DRAFT)
  ageMode            LiveAgeMode              @map("age_mode")
  countdownSec       Int?                     @map("countdown_sec")
  startedAt          DateTime?                @map("started_at")
  finishedAt         DateTime?                @map("finished_at")
  xpAwarded          Boolean                  @default(false) @map("xp_awarded")
  /// Volitelná vazba na kampaň — bleskovka bez kampaně funguje beze změny.
  campaignProgressId String?                  @map("campaign_progress_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  host               Membership               @relation("HostedLiveSessions", fields: [hostId], references: [id], onDelete: Cascade)
  classSection       ClassSection?            @relation(fields: [classSectionId], references: [id], onDelete: SetNull)
  test               Test                     @relation(fields: [testId], references: [id], onDelete: Restrict)
  campaignProgress   CampaignProgress?        @relation(fields: [campaignProgressId], references: [id], onDelete: SetNull)
  campaignStepUnlock CampaignStepUnlock?
  rounds             LiveSessionRound[]
  participants       LiveSessionParticipant[]
  xpEvents           ClassPartakXpEvent[]

  @@index([organizationId, status])
  @@index([hostId, createdAt])
  @@map("live_sessions")
}

/// Jedno kolo bleskovky. Otázka je nasnapshotovaná při startu session —
/// pozdější editace zdrojového testu běžící/ukončenou bleskovku neovlivní.
/// correctKeySnapshot NIKDY neopouští server před revealem (viz service).
/// voteCounts jsou ANONYMNÍ agregáty {"A": 14, "B": 6} z dotykové tabule —
/// žádná vazba na osoby (GDPR záměr režimu B trvá, viz docs/live-sessions.md).
/// Hlasy NIKDY nevstupují do XP ani postupu kampaní (kryto e2e).
model LiveSessionRound {
  id                 String               @id @default(uuid()) @map("live_session_round_id")
  sessionId          String               @map("live_session_id")
  order              Int
  questionId         String?              @map("question_id")
  questionText       String               @map("question_text")
  interactionType    RoundInteractionType @default(QUIZ) @map("interaction_type")
  /// QUIZ only — u interaktivních kol null.
  optionsSnapshot    Json?                @map("options_snapshot")
  /// QUIZ only — u interaktivních kol null.
  correctKeySnapshot String?              @map("correct_key_snapshot")
  /// Interaktivní kola — board-safe obsah (zamíchané kartičky, překlíčovaná
  /// round-local ID, BEZ řešení). Smí na projekci kdykoli.
  contentSnapshot    Json?                @map("content_snapshot")
  /// Interaktivní kola — mapování řešení. NIKDY neopouští server před
  /// dokončením/revealem kola (stejný kontrakt jako correctKeySnapshot).
  solutionSnapshot   Json?                @map("solution_snapshot")
  /// Anonymní agregát průběhu řešení na tabuli: { wrong, placed: {itemId:
  /// targetId}, checks }. Žádná vazba na osoby; do XP nikdy nevstupuje.
  attemptStats       Json?                @map("attempt_stats")
  outcome            LiveRoundOutcome?
  voteCounts         Json?                @map("vote_counts")
  votingStartedAt    DateTime?            @map("voting_started_at")
  revealedAt         DateTime?            @map("revealed_at")
  completedAt        DateTime?            @map("completed_at")
  session            LiveSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question           Question?            @relation(fields: [questionId], references: [id], onDelete: SetNull)

  @@unique([sessionId, order])
  @@map("live_session_rounds")
}

/// Režim A (DEVICES) — tabulka NAVRŽENA, v režimu B se NIKDY nezapisuje.
/// Záměr (GDPR): BOARD_ONLY bleskovka je anonymní na úrovni třídy — o dětech
/// se neukládá vůbec nic. `nickname` je přezdívka zadaná při joinu (ne jméno),
/// `membershipId` se vyplní jen u autentizovaného joinu. Viz docs/live-sessions.md.
model LiveSessionParticipant {
  id           String      @id @default(uuid()) @map("live_session_participant_id")
  sessionId    String      @map("live_session_id")
  nickname     String      @db.VarChar(50)
  joinToken    String      @unique @map("join_token")
  membershipId String?     @map("membership_id")
  joinedAt     DateTime    @default(now()) @map("joined_at")
  lastSeenAt   DateTime?   @map("last_seen_at")
  session      LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  membership   Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@map("live_session_participants")
}

/// Kolektivní parťák třídy. XP POUZE za odehraná kola a dokončené bleskovky,
/// NIKDY za správnost odpovědí (vynuceno typy ClassPartakXpType).
/// Žádné srovnávání tříd v UI ani API — stejné pravidlo jako u individuálního parťáka.
model ClassPartak {
  id             String               @id @default(uuid()) @map("class_partak_id")
  organizationId String               @map("organization_id")
  classSectionId String               @unique @map("class_section_id")
  xp             Int                  @default(0)
  stage          Int                  @default(1)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classSection   ClassSection         @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  xpEvents       ClassPartakXpEvent[]

  @@index([organizationId])
  @@map("class_partaks")
}

model ClassPartakXpEvent {
  id            String            @id @default(uuid()) @map("class_partak_xp_event_id")
  classPartakId String            @map("class_partak_id")
  sessionId     String?           @map("live_session_id")
  type          ClassPartakXpType @map("event_type")
  value         Int
  createdAt     DateTime          @default(now()) @map("created_at")
  classPartak   ClassPartak       @relation(fields: [classPartakId], references: [id], onDelete: Cascade)
  session       LiveSession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([classPartakId, createdAt])
  @@map("class_partak_xp_events")
}

/// Rozehraná kampaň jedné třídy (Výprava/Mise). Kampaň samotná NENÍ v DB —
/// definice žije v server/content/campaigns/*.json (registry, zod validace
/// při bootu); campaignId je slug ze souboru. Třída může mít rozehráno víc
/// kampaní současně. Postup POUZE za dokončené bleskovky s ≥1 odehraným
/// kolem — správnost (outcome) do postupu NIKDY nevstupuje.
model CampaignProgress {
  id                           String                 @id @default(uuid()) @map("campaign_progress_id")
  organizationId               String                 @map("organization_id")
  classSectionId               String                 @map("class_section_id")
  campaignId                   String                 @map("campaign_id")
  campaignType                 CampaignType           @map("campaign_type")
  status                       CampaignProgressStatus @default(ACTIVE)
  position                     Int                    @default(0)
  totalSteps                   Int                    @map("total_steps")
  /// Mise: vzkaz budoucí třídě, píše učitel po dokončení kampaně.
  epilogueMessage              String?                @map("epilogue_message") @db.VarChar(500)
  epilogueSubmittedAt          DateTime?              @map("epilogue_submitted_at")
  /// Snapshot zdroje vzkazu minulé třídy (při startu kampaně). Vzkaz se na
  /// projekci NIKDY nedostane před explicitním revealem učitele TÉTO třídy —
  /// stejný kontrakt jako correctKey u kol.
  predecessorProgressId        String?                @map("predecessor_progress_id")
  predecessorMessageRevealedAt DateTime?              @map("predecessor_message_revealed_at")
  startedAt                    DateTime               @default(now()) @map("started_at")
  completedAt                  DateTime?              @map("completed_at")
  createdAt                    DateTime               @default(now()) @map("created_at")
  updatedAt                    DateTime               @updatedAt @map("updated_at")
  organization                 Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  classSection                 ClassSection           @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  predecessor                  CampaignProgress?      @relation("CampaignEpilogueChain", fields: [predecessorProgressId], references: [id], onDelete: SetNull)
  successors                   CampaignProgress[]     @relation("CampaignEpilogueChain")
  stepUnlocks                  CampaignStepUnlock[]
  sessions                     LiveSession[]

  @@unique([classSectionId, campaignId])
  @@index([organizationId, classSectionId])
  @@index([organizationId, campaignId, status])
  @@map("campaign_progresses")
}

/// 1 řádek = 1 odemčená zastávka (Výprava) / kapitola (Mise). Zároveň JE
/// sbírkou samolepek i nástěnkou fragmentů — assety žijí v campaign JSON
/// pod stepKey. Třídní úroveň, o jednotlivých dětech nic (jako režim B).
/// sessionId @unique = idempotenční kotva: jedna session posune max o 1 krok.
model CampaignStepUnlock {
  id           String           @id @default(uuid()) @map("campaign_step_unlock_id")
  progressId   String           @map("campaign_progress_id")
  stepIndex    Int              @map("step_index")
  stepKey      String           @map("step_key")
  sessionId    String?          @unique @map("live_session_id")
  /// Kolik kol session odehrála — rekapitulace + kosmetika, NIKDY podmínka.
  roundsPlayed Int              @map("rounds_played")
  unlockedAt   DateTime         @default(now()) @map("unlocked_at")
  progress     CampaignProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  session      LiveSession?     @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([progressId, stepIndex])
  @@map("campaign_step_unlocks")
}

/// Immutable analytical snapshot of one SUBMITTED test attempt.
/// Source of truth stays in Submission/Response; this row is a historically valid copy
/// of the context at submit time. No relations to live tables (except ResponseFact) so the
/// snapshot survives deletion/soft-delete of the live test/question/student. See
/// docs/analytics/student-progress-prisma-models.md.
model SubmissionFact {
  id String @id @default(uuid()) @map("submission_fact_id")

  // Source linkage (scalar)
  submissionId String @unique @map("submission_id")
  assignmentId String @map("assignment_id")
  testId       String @map("test_id")
  testVersion  Int    @map("test_version")

  // Identity anchors (each solves a different problem)
  organizationId String  @map("organization_id")
  userId         String  @map("user_id")
  membershipId   String  @map("membership_id")
  studentId      String? @map("student_id")

  // Historical context (frozen at submit time)
  academicYearId   String? @map("academic_year_id")
  classSectionId   String? @map("class_section_id")
  subjectId        String? @map("subject_id")
  catalogSubjectId String? @map("catalog_subject_id")
  topicLevelId     String? @map("topic_level_id")
  catalogTopicId   String? @map("catalog_topic_id")

  // Result
  attemptNo       Int   @map("attempt_no")
  score           Int   @map("score")
  maxScore        Int   @map("max_score")
  percentage      Float @map("percentage")
  questionCount   Int   @map("question_count")
  correctCount    Int   @map("correct_count")
  incorrectCount  Int   @map("incorrect_count")
  unansweredCount Int   @default(0) @map("unanswered_count")

  // Time
  startedAt   DateTime? @map("started_at")
  submittedAt DateTime  @map("submitted_at")
  durationSec Int?      @map("duration_sec")

  // Provenance / extensibility
  dataQuality     AnalyticsDataQuality    @default(COMPLETE) @map("data_quality")
  source          AnalyticsSnapshotSource @default(LIVE_SUBMIT)
  snapshotVersion Int                     @default(1) @map("snapshot_version")
  metadata        Json?
  createdAt       DateTime                @default(now()) @map("created_at")

  responseFacts ResponseFact[]

  @@index([organizationId, userId, submittedAt])
  @@index([userId, submittedAt])
  @@index([membershipId, submittedAt])
  @@index([studentId, submittedAt])
  @@index([academicYearId, submittedAt])
  @@index([subjectId, submittedAt])
  @@index([catalogSubjectId, submittedAt])
  @@index([topicLevelId, submittedAt])
  @@index([catalogTopicId, submittedAt])
  @@map("submission_facts")
}

/// Immutable per-question snapshot of one answer within a submitted attempt.
/// Granularity for mastery and error analysis. Scalar IDs; only relation is to SubmissionFact.
/// Does NOT store correctAnswerSnapshot/explanationSnapshot by design (see docs).
model ResponseFact {
  id String @id @default(uuid()) @map("response_fact_id")

  submissionFactId String @map("submission_fact_id")
  submissionId     String @map("submission_id")
  responseId       String @unique @map("response_id")

  organizationId String  @map("organization_id")
  userId         String  @map("user_id")
  membershipId   String  @map("membership_id")
  studentId      String? @map("student_id")
  academicYearId String? @map("academic_year_id")

  questionId           String       @map("question_id")
  questionOrder        Int?         @map("question_order")
  questionType         QuestionType @map("question_type")
  questionTextSnapshot String?      @map("question_text_snapshot")

  topicLevelId   String?     @map("topic_level_id")
  catalogTopicId String?     @map("catalog_topic_id")
  subjectId      String?     @map("subject_id")
  difficulty     Difficulty? @map("difficulty")

  score         Int      @map("score")
  maxScore      Int      @map("max_score")
  isCorrect     Boolean? @map("is_correct")
  corrected     Boolean  @default(false)
  attemptNumber Int      @default(1) @map("attempt_number")

  givenTextSnapshot String? @map("given_text_snapshot")

  dataQuality     AnalyticsDataQuality @default(COMPLETE) @map("data_quality")
  snapshotVersion Int                  @default(1) @map("snapshot_version")
  responseTimeSec Int?                 @map("response_time_sec")
  metadata        Json?
  createdAt       DateTime             @default(now()) @map("created_at")

  submissionFact SubmissionFact @relation(fields: [submissionFactId], references: [id], onDelete: Cascade)

  @@index([submissionFactId])
  @@map("response_facts")
}

model ImportBatch {
  id             String       @id @default(uuid()) @map("import_batch_id")
  organizationId String       @map("organization_id")
  fileName       String       @map("file_name")
  importedById   String       @map("imported_by_id")
  status         ImportStatus

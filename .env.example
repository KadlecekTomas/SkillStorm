#
# SkillStorm – environment template
#
# Copy this file to `.env` (and optionally to `server/.env`) before starting the stack.
#

# -------------------------------------------------------------------
# Application ports
# -------------------------------------------------------------------
BACKEND_PORT=3000
CLIENT_PORT=3001

# -------------------------------------------------------------------
# PostgreSQL (docker-compose)
# -------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skillstormdb
POSTGRES_PORT=5432

# Connection string used by the NestJS API & Prisma
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/skillstormdb

# -------------------------------------------------------------------
# Backend configuration
# -------------------------------------------------------------------
PORT=3000
JWT_SECRET=super-secret-change-me
CACHE_TTL_SECONDS=600
REDIS_URL=
DISABLE_BOOTSTRAP_SEARCH=0

# -------------------------------------------------------------------
# Frontend configuration
# -------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skillstorm
POSTGRES_PORT=5432
# Backend host port (container listens on 4200 internally). Default 4201 avoids Angular default 4200.
BACKEND_PORT=4201
JWT_SECRET=supersecret
CACHE_TTL_SECONDS=60
REDIS_URL=redis://localhost:6379
DISABLE_BOOTSTRAP_SEARCH=false
CORS_ORIGINS=http://localhost:3000,http://frontend:3000
# API_PROXY_TARGET: backend URL for Next.js rewrites (server-side only, frontend never uses it)
# Local: http://localhost:4200 | Docker: http://backend:4200
API_PROXY_TARGET=http://localhost:4200

# SkillStorm local development environment example.
# Copy to .env for local development only. Never commit real .env files.

NODE_ENV=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_DATABASE_PASSWORD
POSTGRES_DB=skillstorm
POSTGRES_PORT=5432
DATABASE_URL=CHANGE_ME_DATABASE_URL

# Use strong random values even in shared dev environments.
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_STRONG_RANDOM_REFRESH_SECRET
COOKIE_SECRET=CHANGE_ME_STRONG_RANDOM_COOKIE_SECRET
METRICS_INGEST_KEY=CHANGE_ME_LOCAL_METRICS_INGEST_KEY

CACHE_TTL_SECONDS=60
REDIS_URL=redis://localhost:6379

# Local-only toggles. DISABLE_CSRF=1 is forbidden in production.
DISABLE_CSRF=0
DISABLE_BOOTSTRAP_SEARCH=false
ALLOW_PUBLIC_ORG_CREATION=true
RUN_MIGRATIONS=1
RUN_SEED=0
DEMO_SEED=0
DEMO_MODE=0

CORS_ORIGINS=http://localhost:3000,http://frontend:3000
PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4200
ALLOW_CROSS_SITE_COOKIES=0
ENABLE_RBAC_TELEMETRY_CLIENT=0

# API_PROXY_TARGET: backend URL for Next.js rewrites (server-side only, frontend never uses it).
# Local: http://localhost:4200 | Docker: http://backend:4200
API_PROXY_TARGET=http://localhost:4200

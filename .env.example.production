# === CLOSED BETA PRODUCTION ===
# Copy to .env and set real values. No defaults for secrets.

NODE_ENV=production

# Database (required)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=skillstorm
POSTGRES_PORT=5432

# Backend: required in production; container fails if JWT_SECRET not set
JWT_SECRET=
CORS_ORIGINS=https://beta.example.com

# Full DB URL (Docker compose overrides with POSTGRES_*)
DATABASE_URL=postgresql://postgres:PASSWORD@postgres:5432/skillstorm

# First deploy only: required when no SUPERADMIN exists
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Closed beta: comma-separated emails allowed to register. Empty = invite-only.
BETA_ALLOWLIST_EMAILS=
ALLOW_PUBLIC_ORG_CREATION=true

# Optional
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=60
SENTRY_DSN=
BETA_MODE=1

# Frontend (required in production)
API_PROXY_TARGET=http://backend:4200
